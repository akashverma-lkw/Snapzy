{
    "version": 2,
    "builds": [
    { 
      "src": "./backend/server.js", 
      "use": "@vercel/node"
    },
    { "src": "src", "use": "@vercel/static-build" }
  ],
  "routes": [
    { "src": "/(.*)",
      "dest": "server.js"
     },
     { "rewrites": [{ "source": "/(.*)", "destination": "/" }] },
    { "src": "/(.*)", "dest": "/src/$1" }  ]
}